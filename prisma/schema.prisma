generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USER & AUTH ===========
model User {
  id            String    @id @default(cuid())
  clerkId       String    @unique
  email         String    @unique
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creditAccount   CreditAccount?
  actions         ActionLog[]
  brandMemory     BrandMemory?
  productMemories ProductMemory[]
  preferences     UserPreference?
  generations     GenerationHistory[]
}

// ============ BRAND MEMORY ===========
model BrandMemory {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])

  brandName     String?
  tagline      String?
  voice        String?
  tone         String?
  values       String[]
  avoidWords   String[]
  keyMessages  String[]
  competitors  String[]
  goodExamples String[]
  badExamples  String[]
  industry     String?
  description  String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

// ============ PRODUCT MEMORY ===========
model ProductMemory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  description String?
  category    String?
  features    String[]
  benefits    String[]
  differentiators String[]
  targetAudience String[]
  useCases    String[]
  priceRange  String?
  position    String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([userId])
}

// ============ USER PREFERENCE ===========
model UserPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  defaultLanguage String   @default("English")
  defaultTone    String   @default("Professional")
  defaultAudience String?
  preferVariants  Boolean  @default(true)
  preferShortCopy Boolean  @default(false)
  includeEmoji   Boolean  @default(true)
  primaryPlatform String?
  primaryGoal     String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

// ============ GENERATION HISTORY ===========
model GenerationHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  skill       String
  actionType  String
  inputData   String   // JSON stored as string
  generatedContent String
  variants    String[]
  rating      Int?
  userFeedback String?
  usedContent  Boolean  @default(false)
  productId   String?
  brandId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, skill])
  @@index([userId, createdAt])
}

model CreditAccount {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  balance       Int       @default(0) // Credits (integer units)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transactions  CreditTransaction[]
}

model CreditTransaction {
  id          String          @id @default(cuid())
  accountId   String
  account     CreditAccount   @relation(fields: [accountId], references: [id])
  amount      Int             // positive = credit, negative = debit
  type        CreditTxType
  description String?
  createdAt   DateTime        @default(now())
}

enum CreditTxType {
  TOP_UP
  PURCHASE
  ACTION_DEDUCT
  REFUND
  BONUS
}

// ============ ACTIONS & USAGE (User sees) ============
model ActionLog {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  skill       String    // e.g., "copywriting", "ai-seo"
  actionType  String    // e.g., "generate_ad", "optimize_content"
  inputTokens Int       @default(0)
  outputTokens Int      @default(0)
  creditsUsed Int       @default(0)
  createdAt   DateTime  @default(now())
}

// ============ BILLING & COSTS (Boss only - hidden from users) ============
model TokenLog {
  id            String    @id @default(cuid())
  userId        String
  skill         String
  actionType    String
  model         String
  inputTokens   Int
  outputTokens  Int
  inputCostUsd  Decimal   @db.Decimal(10, 6)
  outputCostUsd Decimal   @db.Decimal(10, 6)
  totalCostUsd  Decimal   @db.Decimal(10, 6)
  userPaidUsd   Decimal   @db.Decimal(10, 6) // What user was charged
  marginUsd     Decimal   @db.Decimal(10, 6) // Profit
  createdAt     DateTime  @default(now())
}

model MarginSummary {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  totalRevenueUsd Decimal @db.Decimal(10, 4)
  totalCostUsd    Decimal @db.Decimal(10, 4)
  totalMarginUsd  Decimal @db.Decimal(10, 4)
  totalTokens     Int
  actionCount    Int
  updatedAt      DateTime @updatedAt

  @@unique([date])
}
