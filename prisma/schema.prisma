generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USER & AUTH ============
model User {
  id            String    @id @default(cuid())
  clerkId       String    @unique
  email         String    @unique
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creditAccount   CreditAccount?
  actions         ActionLog[]
  workspaces      Workspace[]
  generations     GenerationHistory[]
  referrals       Referral[]
}

// ============ WORKSPACE ============
model Workspace {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String    // "OmmiCare Shop"
  description   String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  brandMemory   BrandMemory?
  products      Product[]
  campaigns     Campaign[]
  learnings     Learning[]
  generations   GenerationHistory[]
  performances  CampaignPerformance[]

  @@index([userId])
}

// ============ BRAND MEMORY ===========
model BrandMemory {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  brandName     String?
  tagline      String?
  voice        String?
  tone         String?
  values       String[]
  avoidWords   String[]
  keyMessages  String[]
  competitors  String[]
  goodExamples String[]
  badExamples  String[]
  industry     String?
  description  String?

  // Self-improvement: learned patterns
  winningStyles        String[]  // ["情感導向", "母女場景"]
  bestTopics           String[]  // ["母親節", "送禮"]
  bestAudiences        String[]  // ["香港女性 25-40"]

  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

// ============ PRODUCT ===========
model Product {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  url           String    // 原始產品 URL
  name          String
  description   String?
  category      String?
  price        String?

  // AI 分析結果
  features      String[]
  sellingPoints Json?     // [{"point": "...", "category": "benefit", "confirmed": true}]
  competitiveEdge String?

  // 成效數據（aggregate）
  avgCTR        Float?
  avgROAS       Float?
  totalSpend    Float?
  totalConversions Int?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campaigns     Campaign[]
  learnings     Learning[]

  @@index([workspaceId])
}

// ============ CAMPAIGN ===========
model Campaign {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?  @relation(fields: [productId], references: [id])

  name          String    // "母親節 Earbuds 推廣"
  platform      String    @default("facebook") // "facebook" | "instagram" | "both"
  objective     String    @default("sales")    // "awareness" | "lead" | "sales" | "retargeting"
  status        String    @default("draft")   // "draft" | "active" | "paused" | "completed"

  // 預算
  totalBudget   Float?
  currency      String    @default("HKD")

  // 成效 aggregate
  totalImpressions Int?
  totalClicks     Int?
  totalConversions Int?
  totalSpend      Float?
  avgROAS         Float?

  adSets        AdSet[]
  performances  CampaignPerformance[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([workspaceId])
  @@index([productId])
}

// ============ AD SET ===========
model AdSet {
  id            String    @id @default(cuid())
  campaignId    String
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  name          String    // "香港女性 25-40, 興趣:時尚"
  audienceDesc  String?   // 人工可讀的受眾描述

  budget        Float?
  budgetPercent Int?

  ads           Ad[]

  // 成效
  impressions   Int?
  clicks        Int?
  ctr           Float?
  cpc           Float?
  conversions   Int?
  spend         Float?
  roas          Float?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([campaignId])
}

// ============ AD ===========
model Ad {
  id            String    @id @default(cuid())
  adSetId       String
  adSet         AdSet     @relation(fields: [adSetId], references: [id], onDelete: Cascade)

  name          String    // "Ad 1.1"

  // 創意內容
  headline      String?
  primaryText   String?
  cta           String?
  description   String?

  // 素材 Asset
  assetName     String?   // "mother_day_v1.jpg"
  assetType     String?   // "image" | "video" | "carousel"
  assetUrl      String?

  // 成效
  impressions   Int?
  clicks        Int?
  ctr           Float?
  spend         Float?
  conversions   Int?
  videoViews    Int?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([adSetId])
}

// ============ CAMPAIGN PERFORMANCE (Raw CSV Data) ===========
model CampaignPerformance {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // CSV 欄位
  date          DateTime?
  campaignName  String
  adsetName     String
  adName        String
  assetName     String?

  impressions   Int       @default(0)
  clicks        Int       @default(0)
  ctr           Float?
  cpc           Float?
  spend         Float     @default(0)
  conversions   Int       @default(0)
  revenue       Float?
  roas          Float?

  reach         Int?
  frequency     Float?
  videoViews    Int?
  video2SecViews Int?
  thumbnailUrl  String?

  // 關聯
  campaignId    String?
  campaign      Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  uploadedAt    DateTime  @default(now())

  @@index([workspaceId])
  @@index([campaignName])
}

// ============ LEARNING (Self-Improvement) ===========
model Learning {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)

  type          String    // "winning_style" | "audience_insight" | "timing_pattern" | "creative_tip"
  content       String    // "情感導向內容比功能導向 CTR 高 40%"
  confidence    Float     @default(0.5)  // 1.0 = 非常確定
  source        String    // "history_analysis" | "user_feedback" | "a_b_test" | "csv_upload"

  createdAt     DateTime  @default(now())

  @@index([workspaceId])
  @@index([productId])
}

// ============ USER PREFERENCE ===========
model UserPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  clerkId         String   @unique

  defaultLanguage String   @default("English")
  defaultTone    String   @default("Professional")
  defaultAudience String?
  preferVariants  Boolean  @default(true)
  preferShortCopy Boolean  @default(false)
  includeEmoji   Boolean  @default(true)
  primaryPlatform String?
  primaryGoal     String?

  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

// ============ GENERATION HISTORY ===========
model GenerationHistory {
  id          String   @id @default(cuid())
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  skill       String
  actionType  String
  inputData   String   // JSON stored as string
  generatedContent String
  variants    String[]
  rating      Int?
  userFeedback String?
  usedContent  Boolean  @default(false)
  productId   String?
  brandId     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, skill])
  @@index([userId, createdAt])
  @@index([workspaceId])
}

// ============ CREDIT SYSTEM ===========
model CreditAccount {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance       Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transactions  CreditTransaction[]
}

model CreditTransaction {
  id          String          @id @default(cuid())
  accountId   String
  account     CreditAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amount      Int
  type        CreditTxType
  description String?
  createdAt   DateTime        @default(now())
}

enum CreditTxType {
  TOP_UP
  PURCHASE
  ACTION_DEDUCT
  REFUND
  BONUS
  REFERRAL_BONUS
  AFFILIATE_COMMISSION
}

// ============ ACTIONS & USAGE ============
model ActionLog {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill       String
  actionType  String
  inputTokens Int       @default(0)
  outputTokens Int      @default(0)
  creditsUsed Int       @default(0)
  createdAt   DateTime  @default(now())
}

// ============ BILLING & COSTS (Boss only) ============
model TokenLog {
  id            String    @id @default(cuid())
  userId        String
  skill         String
  actionType    String
  model         String
  inputTokens   Int
  outputTokens  Int
  inputCostUsd  Decimal   @db.Decimal(10, 6)
  outputCostUsd Decimal   @db.Decimal(10, 6)
  totalCostUsd  Decimal   @db.Decimal(10, 6)
  userPaidUsd   Decimal   @db.Decimal(10, 6)
  marginUsd     Decimal   @db.Decimal(10, 6)
  createdAt     DateTime  @default(now())
}

model MarginSummary {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  totalRevenueUsd Decimal @db.Decimal(10, 4)
  totalCostUsd    Decimal @db.Decimal(10, 4)
  totalMarginUsd  Decimal @db.Decimal(10, 4)
  totalTokens     Int
  actionCount    Int
  updatedAt      DateTime @updatedAt

  @@unique([date])
}

// ============ REFERRAL / AFFILIATE SYSTEM ============
model Referral {
  id            String    @id @default(cuid())
  referrerId    String    // User who shares the code
  referrer      User      @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  referralCode  String    @unique
  createdAt     DateTime  @default(now())

  referredUsers ReferralUsage[]
  commissions   AffiliateCommission[]

  @@index([referrerId])
  @@index([referralCode])
}

model ReferralUsage {
  id            String    @id @default(cuid())
  referralId    String
  referral      Referral  @relation(fields: [referralId], references: [id], onDelete: Cascade)
  referredUserId String   // The new user who signed up using the code
  signUpBonusAwarded Boolean @default(false)
  firstPurchaseBonusAwarded Boolean @default(false)
  createdAt     DateTime  @default(now())

  @@index([referralId])
  @@index([referredUserId])
}

model AffiliateCommission {
  id            String    @id @default(cuid())
  referralId    String
  referral      Referral  @relation(fields: [referralId], references: [id], onDelete: Cascade)
  referredUserId String   // The user whose purchase generated commission
  purchaseAmount Int      // Credits purchased
  commissionAmount Int    // Credits earned by referrer
  status        String    @default("pending") // "pending" | "credited"
  createdAt     DateTime  @default(now())
  creditedAt    DateTime?

  @@index([referralId])
  @@index([referredUserId])
}
